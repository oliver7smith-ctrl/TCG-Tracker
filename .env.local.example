# ═══════════════════════════════════════════════════════════════
# COLLECTIBLE TRACKER — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values.
# Lines starting with # are comments — do not change them.
# ═══════════════════════════════════════════════════════════════

# ── REQUIRED — App will not start without these ───────────────

# Your Supabase project URL (from Supabase → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase anon key (from Supabase → Settings → API → anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key (from Supabase → Settings → API → service_role)
# KEEP THIS SECRET — never share or commit this to GitHub
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your app's public URL
# During development: http://localhost:3000
# After Vercel deploy: https://your-project.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App display name
NEXT_PUBLIC_APP_NAME=Collectible Tracker

# ── REQUIRED — Founder / Admin Setup ─────────────────────────

# Your email address — this account gets permanent founder access
FOUNDER_EMAIL=your@email.com

# Secret key for cron job security (make up any random 32+ character string)
# Example: xK9mP2qR7vL4nJ8wA3dF6hB5cE1tY0u
CRON_SECRET=replace_with_32_random_characters_here

# ── OPTIONAL — Push Notifications (free) ─────────────────────
# Generate these by running: npx web-push generate-vapid-keys
# Leave blank to disable push notifications

NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:your@email.com

# ── OPTIONAL — Email Alerts via Resend (free tier = 100/day) ─
# Sign up at resend.com — free, no credit card
# Leave blank to disable email alerts

RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=Collectible Tracker

# ── OPTIONAL — SMS Alerts via Twilio (costs money) ───────────
# Only needed if you want SMS alerts — skip for now
# Leave blank to disable SMS

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── OPTIONAL — Stripe Billing (costs nothing until users pay) ─
# Only needed if you want to charge users — skip for testing
# Leave blank to disable billing (all users get free tier)

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PREMIUM_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
